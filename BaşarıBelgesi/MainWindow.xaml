<Window x:Class="BaşarıBelgesi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:System="clr-namespace:System;assembly=mscorlib"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BaşarıBelgesi"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:BaşarıBelgesi.Properties"
    Title="Başarı Belgesi"
    d:Height="1024"
    d:Width="1024"
    DataContext="{DynamicResource BaşarıBelgesiViewModel}"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Window.Resources>
        <CollectionViewSource x:Key="Kurumlar" Source="{Binding SeçiliKurum.Kişi}" />
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <local:BaşarıBelgesiViewModel x:Key="BaşarıBelgesiViewModel" />
        <local:ReverseBooleanConverter x:Key="ReverseBooleanConverter" />
        <Style TargetType="{x:Type HeaderedContentControl}">
            <Setter Property="IsTabStop" Value="False" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="2.5*" />
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <GroupBox Header="KURUM">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <HeaderedContentControl Header="ADI">
                            <TextBox Text="{Binding Kurum.Adi, UpdateSourceTrigger=PropertyChanged}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="AMİR ADI">
                            <TextBox Text="{Binding Kurum.AmirAdi, UpdateSourceTrigger=PropertyChanged}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="AMİR SOYADI">
                            <TextBox Text="{Binding Kurum.AmirSoyadi, UpdateSourceTrigger=PropertyChanged}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="AMİR UNVANI">
                            <TextBox Text="{Binding Kurum.AmirUnvani, UpdateSourceTrigger=PropertyChanged}" />
                        </HeaderedContentControl>
                        <Button Command="{Binding AddLogo}" Content="KURUM LOGO YÜKLE" />
                        <Button Command="{Binding AddKurum}" Content="KURUM EKLE" />
                        <GroupBox Header="KURUMLAR">
                            <ListBox Height="120"
                                d:ItemsSource="{d:SampleData ItemCount=2}"
                                ItemsSource="{Binding Kurumlar.Kurum}"
                                SelectedItem="{Binding SeçiliKurum, ValidatesOnDataErrors=True}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Width="64"
                                                Height="64"
                                                d:Source="App.ico"
                                                RenderOptions.BitmapScalingMode="Fant"
                                                Source="{Binding Logo, Mode=OneWay, Converter={StaticResource ByteToImageConverter}}" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBox VerticalAlignment="Center" Text="{Binding Adi, UpdateSourceTrigger=PropertyChanged}" />
                                                <UniformGrid Columns="3">
                                                    <TextBlock Text="AMİR ADI" />
                                                    <TextBlock Text="AMİR SOYADI" />
                                                    <TextBlock Text="AMİR UNVANI" />
                                                    <TextBox Text="{Binding AmirAdi, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBox Text="{Binding AmirSoyadi, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBox Text="{Binding AmirUnvani, UpdateSourceTrigger=PropertyChanged}" />
                                                </UniformGrid>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel Orientation="Vertical" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
            <GroupBox Grid.Row="1" Header="KİŞİ">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <UniformGrid Columns="2">
                            <HeaderedContentControl Header="ADI">
                                <TextBox Text="{Binding Kişi.Adi, UpdateSourceTrigger=PropertyChanged}" />
                            </HeaderedContentControl>
                            <HeaderedContentControl Header="SOYADI">
                                <TextBox Text="{Binding Kişi.Soyadi, UpdateSourceTrigger=PropertyChanged}" />
                            </HeaderedContentControl>
                            <HeaderedContentControl Header="TC KİMLİK NO">
                                <TextBox MaxLength="11" Text="{Binding Kişi.TC, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                            </HeaderedContentControl>
                            <HeaderedContentControl Header="ÜNVAN">
                                <TextBox Text="{Binding Kişi.Unvan, UpdateSourceTrigger=PropertyChanged}" />
                            </HeaderedContentControl>
                        </UniformGrid>
                        <HeaderedContentControl Header="GÖREV YERİ">
                            <TextBox Text="{Binding Kişi.GorevYeri, UpdateSourceTrigger=PropertyChanged}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="TARİH">
                            <DatePicker SelectedDate="{Binding Kişi.EvrakTarih, UpdateSourceTrigger=PropertyChanged}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="SAYI">
                            <TextBox Text="{Binding Kişi.EvrakSayı, UpdateSourceTrigger=PropertyChanged}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="GEREKÇE">
                            <TextBox SpellCheck.IsEnabled="True"
                                Text="{Binding Kişi.Gerekçe, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="BAŞARI BELGE TİPİ">
                            <UniformGrid Columns="2">
                                <ComboBox IsEditable="True"
                                    SelectedIndex="0"
                                    SelectedItem="{Binding Kişi.BasariBelgeTipi, UpdateSourceTrigger=PropertyChanged}">
                                    <System:String>BAŞARI BELGESİ</System:String>
                                    <System:String>ÜSTÜN BAŞARI BELGESİ</System:String>
                                </ComboBox>
                                <Button Command="{Binding SetBaşarı}"
                                    CommandParameter="{Binding Kişi}"
                                    Content="HIZLI METİN EKLE" />
                            </UniformGrid>
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="AÇIKLAMA">
                            <TextBox Height="100"
                                SpellCheck.IsEnabled="True"
                                Text="{Binding Kişi.BasariBelgeAciklama, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </HeaderedContentControl>
                        <Button Command="{Binding AddKişi}" Content="KİŞİ EKLE" />
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
        <Grid Grid.Column="1" Background="{DynamicResource BorderBackground}">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DataGrid d:ItemsSource="{d:SampleData ItemCount=3}"
                AutoGenerateColumns="False"
                Background="{DynamicResource BorderBackground}"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                ItemsSource="{Binding Source={StaticResource Kurumlar}}"
                SelectedItem="{Binding SeçiKişi}">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding Seçili, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" CanUserSort="False">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                        <DataGridCheckBoxColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Command="{Binding KişiTümünüSeç, Mode=OneWay, Source={StaticResource BaşarıBelgesiViewModel}}" IsChecked="{Binding TümüSeçili, Source={StaticResource BaşarıBelgesiViewModel}}" />
                            </DataTemplate>
                        </DataGridCheckBoxColumn.HeaderTemplate>
                    </DataGridCheckBoxColumn>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding KişiSil, Mode=OneWay, Source={StaticResource BaşarıBelgesiViewModel}}"
                                    CommandParameter="{Binding}"
                                    Content="SİL" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="RESİM">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Width="128"
                                    Height="128"
                                    Source="{Binding Resim, Converter={StaticResource ByteToImageConverter}, Mode=OneWay}">
                                    <Image.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Command="{Binding ResimKaydet, Source={StaticResource BaşarıBelgesiViewModel}}"
                                                CommandParameter="{Binding}"
                                                Header="RESİM KAYDET" />
                                            <MenuItem Command="{Binding ResimSil, Source={StaticResource BaşarıBelgesiViewModel}}"
                                                CommandParameter="{Binding}"
                                                Header="RESİM SİL" />
                                        </ContextMenu>
                                    </Image.ContextMenu>
                                </Image>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <Button Width="128"
                                    Height="128"
                                    Command="{Binding AddKişiLogo, Mode=OneWay, Source={StaticResource BaşarıBelgesiViewModel}}"
                                    Content="RESİM EKLE/GÜNCELLE" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="TC KİMLİK NO">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox MaxLength="11" Text="{Binding TC, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Binding="{Binding Adi, UpdateSourceTrigger=PropertyChanged}" Header="ADI" />
                    <DataGridTextColumn Binding="{Binding Soyadi, UpdateSourceTrigger=PropertyChanged}" Header="SOYADI" />
                    <DataGridTextColumn Binding="{Binding Unvan, UpdateSourceTrigger=PropertyChanged}" Header="ÜNVAN" />

                    <DataGridTemplateColumn Width="300" Header="AÇIKLAMA">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding BasariBelgeAciklama}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox SpellCheck.IsEnabled="True"
                                    Text="{Binding BasariBelgeAciklama, UpdateSourceTrigger=PropertyChanged}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Binding="{Binding GorevYeri}" Header="GÖREV YERİ" />
                    <DataGridTextColumn Binding="{Binding EvrakSayı, UpdateSourceTrigger=PropertyChanged}" Header="EVRAK SAYI" />
                    <DataGridTemplateColumn Header="EVRAK TARİH">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding EvrakTarih, UpdateSourceTrigger=PropertyChanged, StringFormat=\{0:d\}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="150" Header="GEREKÇE">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Gerekçe}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Gerekçe, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
            <UniformGrid Grid.Row="1" Columns="2">
                <TextBlock Text="İSİM ARA" />
                <TextBox Text="{Binding Arama, UpdateSourceTrigger=PropertyChanged}" />
            </UniformGrid>
            <ProgressBar Grid.Row="2"
                Height="20"
                IsIndeterminate="{Binding Indeterminate}" />
            <UniformGrid Grid.Row="3" Rows="3">
                <UniformGrid Columns="3">
                    <Button Command="{Binding SetBackgroundImage}" Content="ARKAPLAN RESİM" />
                    <Button Command="{Binding SetDefaultImage}" Content="VARSAYILAN RESİM" />
                    <Button Command="{Binding OpenDataBaseFolder}" Content="VERİTABANI YOLU" />
                </UniformGrid>
                <UniformGrid Columns="2">
                    <ComboBox VerticalContentAlignment="Center"
                        ItemsSource="{Binding Source={x:Static Fonts.SystemFontFamilies}}"
                        SelectedValue="{Binding GövdeYazıTipi, Mode=TwoWay, Source={x:Static properties:Settings.Default}, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="Source">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="{Binding Mode=OneWay}" Text="{Binding Mode=OneWay}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ComboBox.ItemsPanel>
                    </ComboBox>
                    <ComboBox ItemsSource="{Binding FontSize, Mode=OneWay}" SelectedItem="{Binding GövdeYazıTipiSize, Mode=TwoWay, Source={x:Static properties:Settings.Default}, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox SelectedIndex="0" SelectedItem="{Binding GövdeYazıStyle, Mode=TwoWay, Source={x:Static properties:Settings.Default}, UpdateSourceTrigger=PropertyChanged}">
                        <System:String>Normal</System:String>
                        <System:String>Italic</System:String>
                    </ComboBox>
                    <ComboBox SelectedIndex="0" SelectedItem="{Binding GövdeYazıBoldStyle, Mode=TwoWay, Source={x:Static properties:Settings.Default}, UpdateSourceTrigger=PropertyChanged}">
                        <System:String>Normal</System:String>
                        <System:String>Bold</System:String>
                    </ComboBox>
                </UniformGrid>
                <Button Command="{Binding ŞablonGöster}" Content="EXCEL ŞABLONU AL" />
                <Button Command="{Binding ExceldenAl}" Content="EXCELDEN VERİ AL" />
                <Button Command="{Binding Sakla}" Content="VERİLERİ KAYDET" />
                <UniformGrid Columns="2" IsEnabled="{Binding Indeterminate, Converter={StaticResource ReverseBooleanConverter}}">
                    <Button Command="{Binding BaşarıBelgesiÇıkar}" Content="BAŞARI BELGESİ GÖSTER" />
                    <Button Command="{Binding PdfBaşarıBelgesiÇıkar}" Content="PDF BAŞARI BELGESİ ÇIKAR" />
                </UniformGrid>

            </UniformGrid>
        </Grid>
    </Grid>
</Window>