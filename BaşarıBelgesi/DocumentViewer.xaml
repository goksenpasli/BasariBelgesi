<Window x:Class="BaşarıBelgesi.DocumentViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:BaşarıBelgesi"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Başlık}"
    Width="800" Height="450"
    ShowInTaskbar="False" WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Command="{Binding OpenFile}" Content="XPS GÖRÜNTÜLEYİCİSİ İLE GÖSTER" />
        <DocumentViewer Grid.Row="1" Document="{Binding Document}" />
    </Grid>
</Window>